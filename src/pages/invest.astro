---
/**
 * /invest — Public investor funnel.
 *
 * Flow:
 *   1. Hook  → tagline + 4 public-safe market signals
 *   2. Thesis → 3 sentences, no numbers we shouldn't say publicly
 *   3. Form  → accreditation fork (Yes / Not sure / No) drives segment
 *      - Yes        → tagged investor-accredited, founder replies w/ brief + call link
 *      - Not sure   → tagged investor-unverified, founder reply asks qualifying Q
 *      - No         → tagged investor-retail, joins Reg CF waitlist via same form
 *
 * IMPORTANT: this page must not contain confidential numbers (valuation,
 * raise size, cap table, ownership splits). Those live behind the
 * (noindex'd) /investor-pitch/* pages, shared by link only.
 */
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import { FORMSPREE, SEGMENTS } from "../lib/forms";
---

<Base title="Invest | OSCEN" description="Back a neuromorphic brain for robots. Patent pending. Submit interest and we'll send the brief.">
  <Nav />

  <main class="pt-32 pb-24">
    <!-- 1. Hook -->
    <section class="max-w-5xl mx-auto px-6 mb-10">
      <p class="reveal text-[10px] font-mono text-text-muted uppercase tracking-[0.3em] mb-6">Path A · Investors</p>
      <h1 class="reveal font-display text-[clamp(2.5rem,6vw,4.5rem)] text-text-primary leading-[0.9]">
        Everyone is building the body.<br />
        <span class="italic gradient-text">We're building the brain.</span>
      </h1>
      <p class="reveal text-text-secondary mt-8 max-w-2xl text-lg leading-relaxed">
        A spiking neural network that learns continuously, never forgets, and is designed to run on a fraction of the power of today's AI. The brain is real and training right now. The body is what we build next, with you.
      </p>
    </section>

    <!-- 2. Public-safe market signals (no internal numbers) -->
    <section class="max-w-5xl mx-auto px-6 mb-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {[
          { value: "$1.4T", label: "Robotics market by 2030", sub: "Goldman Sachs", color: "text-accent-blue" },
          { value: "$200M+", label: "Neuromorphic VC in 2025", sub: "3× from 2024", color: "text-accent-amber" },
          { value: "1.15M", label: "Neurons training live", sub: "Today, not pitched", color: "text-accent-green" },
          { value: "0", label: "SNN robotics competitors", sub: "Commercial deployment", color: "text-accent-purple" },
        ].map((stat) => (
          <div class="reveal glass-bright rounded-xl p-4 text-center">
            <div class={`text-xl md:text-2xl font-mono font-bold ${stat.color}`}>{stat.value}</div>
            <div class="text-[10px] text-text-muted mt-2 uppercase tracking-wider leading-tight">{stat.label}</div>
            <div class="text-[10px] text-text-muted/60 mt-2">{stat.sub}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- 3. Thesis — short, no numbers -->
    <section class="max-w-5xl mx-auto px-6 mb-10">
      <div class="reveal glass-bright rounded-2xl p-6 md:p-8">
        <p class="text-[10px] font-mono text-text-muted uppercase tracking-[0.3em] mb-6">Investment thesis</p>
        <div class="space-y-4 text-lg text-text-secondary leading-relaxed max-w-3xl">
          <p>Every robot will need a brain. Today's AI is frozen the day it's trained, can't adapt without retraining from scratch, and underneath is just predicting text.</p>
          <p>OSCEN is a neuromorphic brain that learns on the fly by association, uses reward and stress to learn from outcomes, doesn't forget old skills when it learns new ones, and is designed to run on a fraction of the power.</p>
          <p>The architecture is patent pending. The brain is training continuously today. <span class="text-accent-blue">The body is what we build next.</span></p>
        </div>
      </div>
    </section>

    <!-- 4. The form — the only conversion on this page -->
    <section id="investor-form" class="max-w-3xl mx-auto px-6 mb-10 scroll-mt-24">
      <h2 class="reveal font-display text-[clamp(2rem,4.5vw,3rem)] text-text-primary leading-tight mb-3">
        Start the conversation.
      </h2>
      <p class="reveal text-sm text-text-secondary mb-8 max-w-xl">
        Tell us who you are. We'll reply within 48 hours with the brief — what we're raising, milestones, and a call link if you're a fit.
      </p>

      <form
        id="investor-form-el"
        class="reveal glass-bright rounded-2xl p-7 md:p-9 space-y-6 shadow-2xl shadow-black/40"
        action={FORMSPREE.investor}
        method="POST"
      >
        <!-- Routing field. JS upgrades based on accreditation answer.
             Default is "unverified" so non-JS submits still land in a safe bucket. -->
        <input type="hidden" name="segment" value={SEGMENTS.investorUnverified} />
        <input type="hidden" name="_subject" value="New investor inquiry from oscen.ai" />
        <div class="hidden" aria-hidden="true">
          <label>Don't fill this: <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" /></label>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <label class="block">
            <span class="text-[11px] font-mono text-text-secondary uppercase tracking-wider">Name</span>
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              class="mt-2 w-full px-4 py-2.5 rounded-lg bg-deep border border-border-bright text-sm text-text-primary placeholder-text-muted focus:border-accent-amber focus:ring-2 focus:ring-accent-amber/30 focus:outline-none transition-all"
            />
          </label>
          <label class="block">
            <span class="text-[11px] font-mono text-text-secondary uppercase tracking-wider">Email</span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              class="mt-2 w-full px-4 py-2.5 rounded-lg bg-deep border border-border-bright text-sm text-text-primary placeholder-text-muted focus:border-accent-amber focus:ring-2 focus:ring-accent-amber/30 focus:outline-none transition-all"
            />
          </label>
        </div>

        <!-- Accreditation. Required. No default selection. -->
        <fieldset>
          <legend class="text-[11px] font-mono text-text-secondary uppercase tracking-wider">
            Are you an accredited investor in the US?
            <span class="ml-2 text-text-muted/50 normal-case tracking-normal" title="An accredited investor has $200K+ annual income ($300K joint), $1M+ net worth excluding home, or holds qualifying licenses. SEC rule.">
              (what's this?)
            </span>
          </legend>
          <div class="mt-3 grid grid-cols-1 sm:grid-cols-3 gap-2">
            {[
              { value: "yes", label: "Yes, accredited" },
              { value: "not-sure", label: "Not sure" },
              { value: "no", label: "No (Reg CF waitlist)" },
            ].map((opt) => (
              <label class="cursor-pointer">
                <input type="radio" name="accreditation" value={opt.value} required class="peer sr-only" />
                <span class="block px-4 py-3 rounded-lg border border-border-bright bg-deep text-sm text-text-secondary text-center hover:border-accent-amber/40 hover:text-text-primary peer-checked:border-accent-amber peer-checked:bg-accent-amber/15 peer-checked:text-accent-amber peer-focus-visible:ring-2 peer-focus-visible:ring-accent-amber/40 transition-all">
                  {opt.label}
                </span>
              </label>
            ))}
          </div>
        </fieldset>

        <!-- Conditional fields: shown only when accreditation = yes or not-sure -->
        <div id="accredited-fields" class="hidden space-y-5">
          <label class="block">
            <span class="text-[11px] font-mono text-text-secondary uppercase tracking-wider">Check size (optional)</span>
            <select
              name="check_size"
              class="mt-2 w-full px-4 py-2.5 rounded-lg bg-deep border border-border-bright text-sm text-text-primary focus:border-accent-amber focus:ring-2 focus:ring-accent-amber/30 focus:outline-none transition-all"
            >
              <option value="">Select range</option>
              <option value="25-100k">$25K – $100K</option>
              <option value="100-500k">$100K – $500K</option>
              <option value="500k-1m">$500K – $1M</option>
              <option value="1m+">$1M+</option>
              <option value="other">Other / strategic</option>
            </select>
          </label>
          <label class="block">
            <span class="text-[11px] font-mono text-text-secondary uppercase tracking-wider">LinkedIn or website</span>
            <input
              type="url"
              name="linkedin"
              inputmode="url"
              placeholder="https://linkedin.com/in/..."
              class="mt-2 w-full px-4 py-2.5 rounded-lg bg-deep border border-border-bright text-sm text-text-primary placeholder-text-muted focus:border-accent-amber focus:ring-2 focus:ring-accent-amber/30 focus:outline-none transition-all"
            />
            <span class="text-[10px] text-text-muted/60 mt-1 block">Helps us reply quickly. Not required but recommended.</span>
          </label>
        </div>

        <label class="block">
          <span class="text-[11px] font-mono text-text-secondary uppercase tracking-wider">Anything you want us to know? (optional)</span>
          <textarea
            name="message"
            rows="3"
            class="mt-2 w-full px-4 py-2.5 rounded-lg bg-deep border border-border-bright text-sm text-text-primary placeholder-text-muted focus:border-accent-amber focus:ring-2 focus:ring-accent-amber/30 focus:outline-none transition-all resize-none"
          ></textarea>
        </label>

        <label class="flex items-start gap-3 text-xs text-text-muted">
          <input type="checkbox" name="consent" required class="mt-0.5" style="accent-color: var(--color-accent-amber);" />
          <span>I consent to OSCEN contacting me about this inquiry. We won't share your info.</span>
        </label>

        <button
          type="submit"
          id="investor-submit"
          class="w-full px-7 py-3 rounded-full bg-accent-amber/15 border border-accent-amber/30 text-accent-amber font-medium hover:bg-accent-amber/25 hover:border-accent-amber/50 transition-all duration-300 cursor-pointer disabled:opacity-50"
        >
          Send
        </button>

        <p id="investor-status" class="text-center text-sm font-mono hidden"></p>
      </form>

      <div id="investor-success" class="hidden reveal glass-bright rounded-2xl p-9 text-center">
        <p class="text-[10px] font-mono text-accent-green uppercase tracking-[0.3em] mb-3">Received</p>
        <h3 class="font-display text-2xl text-text-primary">Thanks. We'll be in touch within 48 hours.</h3>
        <p id="investor-success-detail" class="text-sm text-text-secondary mt-3 max-w-md mx-auto leading-relaxed"></p>
      </div>

      <p class="reveal text-[10px] text-text-muted/60 mt-6 text-center max-w-xl mx-auto leading-relaxed">
        Nothing on this page constitutes an offer to sell or a solicitation to buy any security. All conversations are subject to applicable securities law.
      </p>
    </section>

    <!-- Back -->
    <section class="max-w-5xl mx-auto px-6 text-center">
      <div class="divider max-w-24 mx-auto mb-10"></div>
      <a href="/" class="text-sm font-mono text-accent-blue/70 hover:text-accent-blue transition-colors">← Back to overview</a>
    </section>
  </main>
</Base>

<script>
  import { SEGMENTS, submitFormspree } from "../lib/forms";

  const form = document.getElementById("investor-form-el") as HTMLFormElement | null;
  const btn = document.getElementById("investor-submit") as HTMLButtonElement | null;
  const status = document.getElementById("investor-status") as HTMLElement | null;
  const accreditedFields = document.getElementById("accredited-fields") as HTMLElement | null;
  const successCard = document.getElementById("investor-success") as HTMLElement | null;
  const successDetail = document.getElementById("investor-success-detail") as HTMLElement | null;

  // Reflect accreditation choice into the UI + hidden routing segment.
  // No-selection → keep the safe default (investor-unverified) in the segment field.
  // "no" hides the accredited-only fields entirely (retail goes straight to the
  // Reg CF waitlist without check-size theatre).
  function updateAccreditationUI() {
    if (!form || !accreditedFields) return;
    const selected = form.querySelector<HTMLInputElement>('input[name="accreditation"]:checked');
    if (!selected) {
      accreditedFields.classList.add("hidden");
      return;
    }
    accreditedFields.classList.toggle("hidden", selected.value === "no");

    const segmentInput = form.querySelector<HTMLInputElement>('input[name="segment"]');
    if (segmentInput) {
      segmentInput.value =
        selected.value === "yes"
          ? SEGMENTS.investorAccredited
          : selected.value === "no"
          ? SEGMENTS.investorRetail
          : SEGMENTS.investorUnverified;
    }
  }

  form?.querySelectorAll<HTMLInputElement>('input[name="accreditation"]').forEach((input) => {
    input.addEventListener("change", updateAccreditationUI);
  });

  if (form && btn && status && successCard && successDetail) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      submitFormspree(form, btn, status, () => {
        const selected = form.querySelector<HTMLInputElement>('input[name="accreditation"]:checked');
        successDetail.textContent =
          selected?.value === "yes"
            ? "We'll reply with the investor brief and a call link."
            : selected?.value === "no"
            ? "You're on the Reg CF waitlist. We'll notify you when our community raise opens."
            : "We'll reply with a quick qualifying question, then the brief.";
        form.classList.add("hidden");
        successCard.classList.remove("hidden");
      });
    });
  }
</script>
