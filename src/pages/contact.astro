---
/**
 * Contact — Partnership, investment, careers, and research inquiries.
 * Clean form. Three paths. Direct email fallback.
 */
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";

const paths = [
  {
    title: "Invest",
    desc: "Fund the brain that powers autonomous robots. Seed-stage, patent-protected.",
    accent: "accent-amber",
  },
  {
    title: "Partner",
    desc: "Your robots, our brain. License OSCEN for your platform, edge hardware, or silicon.",
    accent: "accent-blue",
  },
  {
    title: "Build",
    desc: "Join the team. Neuromorphic computing, robotics, and computational neuroscience roles.",
    accent: "accent-purple",
  },
];
---

<Base title="Contact | OSCEN" description="Partner with OSCEN, invest in neuromorphic robotics intelligence, or join the team building the brain for every robot.">
  <Nav />

  <main class="pt-32 pb-24">
    <!-- Page header -->
    <section class="max-w-4xl mx-auto px-6 mb-16">
      <p class="reveal text-[10px] font-mono text-text-muted uppercase tracking-[0.3em] mb-6">Contact</p>
      <h1 class="reveal font-display text-[clamp(2.5rem,6vw,4.5rem)] text-text-primary leading-[0.9]">
        Let's build the<br />
        <span class="italic gradient-text">future together.</span>
      </h1>
      <p class="reveal text-text-secondary mt-8 max-w-2xl text-lg leading-relaxed">
        Whether you're a robotics company looking for adaptive intelligence, an investor funding the next wave of AI,
        or an engineer who wants to work on something that matters.
      </p>
    </section>

    <!-- Three paths -->
    <section class="max-w-4xl mx-auto px-6 mb-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        {paths.map((p) => (
          <div class={`reveal glass rounded-xl p-6 text-center`}>
            <div class={`text-lg font-medium text-${p.accent}`}>{p.title}</div>
            <p class="text-xs text-text-muted mt-2 leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Contact Form -->
    <section class="max-w-4xl mx-auto px-6 mb-24">
      <div class="reveal glass-bright rounded-2xl p-8 md:p-10">
        <h2 class="text-xl font-medium text-text-primary mb-8">Get in touch</h2>
        <form id="contact-form" class="space-y-6" action="https://formspree.io/f/xzdkgdol" method="POST">
          <input type="hidden" name="_subject" value="New contact from oscen.ai" />
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-xs font-mono text-text-muted uppercase tracking-wider mb-2">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-lg bg-void/50 border border-border text-sm text-text-primary placeholder-text-muted/40 focus:border-accent-blue/30 focus:outline-none transition-colors"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="email" class="block text-xs font-mono text-text-muted uppercase tracking-wider mb-2">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-lg bg-void/50 border border-border text-sm text-text-primary placeholder-text-muted/40 focus:border-accent-blue/30 focus:outline-none transition-colors"
                placeholder="you@company.com"
              />
            </div>
          </div>

          <div>
            <label for="type" class="block text-xs font-mono text-text-muted uppercase tracking-wider mb-2">I'm interested in</label>
            <select
              id="type"
              name="type"
              class="w-full px-4 py-3 rounded-lg bg-void/50 border border-border text-sm text-text-primary focus:border-accent-blue/30 focus:outline-none transition-colors"
            >
              <option value="partnership">Partnership: robotics integration</option>
              <option value="investment">Investment: funding OSCEN</option>
              <option value="careers">Careers: joining the team</option>
              <option value="research">Research: academic collaboration</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="company" class="block text-xs font-mono text-text-muted uppercase tracking-wider mb-2">Company / Organization</label>
            <input
              type="text"
              id="company"
              name="company"
              class="w-full px-4 py-3 rounded-lg bg-void/50 border border-border text-sm text-text-primary placeholder-text-muted/40 focus:border-accent-blue/30 focus:outline-none transition-colors"
              placeholder="Optional"
            />
          </div>

          <div>
            <label for="message" class="block text-xs font-mono text-text-muted uppercase tracking-wider mb-2">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 rounded-lg bg-void/50 border border-border text-sm text-text-primary placeholder-text-muted/40 focus:border-accent-blue/30 focus:outline-none transition-colors resize-none"
              placeholder="Tell us about your project, interest, or how you'd like to collaborate."
            ></textarea>
          </div>

          <!-- Honeypot -->
          <div class="hidden" aria-hidden="true">
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
          </div>

          <div class="flex items-center gap-4">
            <button
              type="submit"
              id="contact-submit"
              class="px-8 py-3 rounded-full bg-accent-blue/10 border border-accent-blue/20 text-accent-blue font-medium hover:bg-accent-blue/20 hover:border-accent-blue/40 transition-all duration-300 cursor-pointer"
            >
              Send message
            </button>
            <p id="contact-status" class="text-sm font-mono hidden"></p>
          </div>
        </form>
      </div>
    </section>

    <!-- Direct contact -->
    <section class="max-w-4xl mx-auto px-6 text-center mb-16">
      <p class="reveal text-sm text-text-muted">
        Prefer email? Reach us directly at
        <a href="mailto:info@oscen.ai" class="text-accent-blue hover:text-accent-blue/80 transition-colors">info@oscen.ai</a>
      </p>
    </section>

    <!-- Back to home -->
    <section class="max-w-4xl mx-auto px-6 text-center">
      <div class="divider max-w-24 mx-auto mb-10"></div>
      <a href="/" class="text-sm font-mono text-accent-blue/70 hover:text-accent-blue transition-colors">&larr; Back to overview</a>
    </section>
  </main>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const btn = document.getElementById('contact-submit') as HTMLButtonElement;
    const status = document.getElementById('contact-status') as HTMLElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      btn.textContent = 'Sending...';
      status.classList.add('hidden');

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          form.reset();
          status.textContent = 'Message sent. We\'ll be in touch.';
          status.className = 'text-sm font-mono text-accent-blue';
        } else {
          const data = await res.json();
          status.textContent = data?.errors?.[0]?.message || 'Something went wrong. Please try again.';
          status.className = 'text-sm font-mono text-red-400';
        }
      } catch {
        status.textContent = 'Network error. Please try again.';
        status.className = 'text-sm font-mono text-red-400';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Send message';
      }
    });
  </script>
</Base>
