---
/**
 * Investor Pitch — The Ask
 * Staged raise: seed now, Series A after proof.
 */
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import PitchNav from "../../components/PitchNav.astro";
import {
  RAISE_AMOUNT, PRE_MONEY_VALUATION, POST_MONEY_VALUATION,
  FOUNDER_OWNERSHIP_POST, INVESTOR_OWNERSHIP,
  SERIES_A_TARGET, SERIES_A_VALUATION,
  USE_OF_FUNDS, MILESTONES, REVENUE_MODEL, REVENUE_SOURCES, COMPARABLES, NON_DILUTIVE,
} from "../../data/pitch";
---

<Base title="The Ask | OSCEN Investor Pitch" description="OSCEN seed: $10M at $30M pre-money. Use of funds, 18-month milestones, business model, and Series A path.">
  <Nav />
  <PitchNav current="ask" />

  <main class="pt-8 pb-24">

    <!-- Header -->
    <section class="max-w-5xl mx-auto px-6 pt-16 mb-20">
      <p class="reveal text-[10px] font-mono text-text-muted uppercase tracking-[0.3em] mb-6">The Ask</p>
      <h1 class="reveal font-display text-[clamp(2.5rem,6vw,4.5rem)] text-text-primary leading-[0.85]">
        <span class="gradient-text">{RAISE_AMOUNT}</span> seed.
      </h1>
      <p class="reveal text-text-secondary mt-6 max-w-2xl leading-relaxed">
        To hire 5 elite engineers, deploy on neuromorphic hardware, build the first robot demo, and reach paid pilots within 18 months.
        A {SERIES_A_TARGET} Series A follows after hardware validation and first revenue.
      </p>
    </section>

    <!-- Two-Round Strategy -->
    <section class="max-w-5xl mx-auto px-6 mb-32">
      <div class="reveal glass-bright rounded-2xl p-8 md:p-10">
        <p class="text-[10px] font-mono text-text-muted uppercase tracking-[0.3em] mb-8">Staged De-Risking</p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <div class="glass rounded-xl p-6 border border-accent-blue/20">
            <span class="text-[9px] font-mono text-accent-blue uppercase tracking-wider">Now</span>
            <div class="text-3xl font-mono font-bold text-accent-blue mt-2">{RAISE_AMOUNT}</div>
            <div class="text-sm text-text-primary font-medium mt-1">Seed Round</div>
            <div class="text-[11px] text-text-secondary mt-3 leading-relaxed space-y-1">
              <p>5 elite hires</p>
              <p>Neuromorphic hardware deployment</p>
              <p>First physical robot demo</p>
              <p>First paid pilots</p>
            </div>
          </div>
          <div class="glass rounded-xl p-6 border border-border/50 opacity-70">
            <span class="text-[9px] font-mono text-text-muted uppercase tracking-wider">After proof</span>
            <div class="text-3xl font-mono font-bold text-text-secondary mt-2">{SERIES_A_TARGET}</div>
            <div class="text-sm text-text-primary font-medium mt-1">Series A</div>
            <div class="text-[11px] text-text-secondary mt-3 leading-relaxed space-y-1">
              <p>Scale to 10M+ neurons</p>
              <p>Multiple robot form factors</p>
              <p>IP portfolio at 8+ patents</p>
              <p>Revenue from OEM licensing</p>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
          <div>
            <div class="text-xl md:text-2xl font-mono font-bold text-accent-blue">{RAISE_AMOUNT}</div>
            <div class="text-[10px] text-text-muted mt-1">Seed raise</div>
          </div>
          <div>
            <div class="text-xl md:text-2xl font-mono font-bold text-accent-purple">{PRE_MONEY_VALUATION}</div>
            <div class="text-[10px] text-text-muted mt-1">Pre-money valuation</div>
          </div>
          <div>
            <div class="text-xl md:text-2xl font-mono font-bold text-accent-cyan">{FOUNDER_OWNERSHIP_POST}</div>
            <div class="text-[10px] text-text-muted mt-1">Founder retains</div>
          </div>
          <div>
            <div class="text-xl md:text-2xl font-mono font-bold text-accent-green">{INVESTOR_OWNERSHIP}</div>
            <div class="text-[10px] text-text-muted mt-1">Investor equity</div>
          </div>
        </div>

        <p class="text-[10px] text-text-muted text-center mt-6">
          Priced equity round. Investors prefer staged de-risking. Seed proves the technology, Series A scales the business.
        </p>
      </div>
    </section>

    <!-- Use of Funds -->
    <section class="max-w-5xl mx-auto px-6 mb-32">
      <h2 class="reveal font-display text-[clamp(1.5rem,3vw,2.5rem)] text-text-primary mb-4">
        Use of funds
      </h2>
      <p class="reveal text-sm text-text-muted mb-12">18-month deployment plan. Every dollar mapped to a milestone.</p>

      <!-- Visual bar chart -->
      <div class="reveal glass rounded-xl p-6 mb-6">
        <div class="space-y-3">
          {USE_OF_FUNDS.map((item) => (
            <div>
              <div class="flex items-center justify-between mb-1">
                <div class="flex items-center gap-3">
                  <span class="text-[10px] font-mono text-text-muted">{item.icon}</span>
                  <span class="text-sm text-text-primary">{item.category}</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class={`text-sm font-mono font-bold text-${item.color}`}>{item.amount}</span>
                  <span class="text-[9px] text-text-muted">{item.percentage}</span>
                </div>
              </div>
              <div class="h-2 rounded-full bg-elevated overflow-hidden ml-8">
                <div
                  class={`h-full rounded-full bg-${item.color}/50`}
                  style={`width: ${(item.amountNum / 4) * 100}%`}
                ></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Expand details -->
      <div class="space-y-2">
        {USE_OF_FUNDS.map((item, i) => (
          <div class="expand-card reveal glass rounded-xl p-4 cursor-pointer group" tabindex="0" style={`--glow-delay: ${i * 1.5}s; --glow-color: var(--color-${item.color});`}>
            <div class="flex items-center gap-3">
              <span class={`text-sm font-mono font-bold text-${item.color}`}>{item.amount}</span>
              <span class="text-sm text-text-primary">{item.category}</span>
              <span class="expand-indicator text-text-muted/40 text-sm ml-auto">+</span>
            </div>
            <div class="expand-body mt-3 ml-16">
              <p class="text-[11px] text-text-secondary leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- 24-Month Milestones -->
    <section class="max-w-5xl mx-auto px-6 mb-32">
      <h2 class="reveal font-display text-[clamp(1.5rem,3vw,2.5rem)] text-text-primary mb-4">
        18-month milestones
      </h2>

      <div class="reveal glass-bright rounded-2xl p-6">
        <div class="space-y-0">
          {MILESTONES.map((m, i) => (
            <div class="flex gap-4 items-start py-4 border-b border-border/50 last:border-0">
              <div class="shrink-0 w-16">
                <span class="text-[10px] font-mono text-accent-blue uppercase">{m.quarter}</span>
              </div>
              <div class="flex-1">
                <h3 class="text-sm font-medium text-text-primary">{m.title}</h3>
                <p class="text-[11px] text-text-secondary mt-1 leading-relaxed">{m.description}</p>
              </div>
              <div class="shrink-0 text-right">
                <span class="px-2 py-0.5 rounded-full bg-accent-green/10 text-accent-green text-[9px] font-mono">
                  {m.metric}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Revenue Model -->
    <section class="max-w-5xl mx-auto px-6 mb-32">
      <h2 class="reveal font-display text-[clamp(1.5rem,3vw,2.5rem)] text-text-primary mb-4">
        Path to revenue
      </h2>
      <p class="reveal text-sm text-text-muted mb-12">Multiple revenue streams reduce risk. Government validates, BaaS scales, IP licensing compounds.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {REVENUE_MODEL.map((phase) => (
          <div class="reveal glass rounded-xl p-5">
            <span class="text-[10px] font-mono text-text-muted uppercase tracking-wider">{phase.year}</span>
            <div class="text-xl font-mono font-bold text-accent-amber mt-2">{phase.range}</div>
            <h3 class="text-sm text-text-primary font-medium mt-2">{phase.model}</h3>
            <p class="text-[11px] text-text-secondary mt-2 leading-relaxed">{phase.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Business Model -->
    <section class="max-w-5xl mx-auto px-6 mb-32">
      <h2 class="reveal font-display text-[clamp(1.5rem,3vw,2.5rem)] text-text-primary mb-4">
        Business model
      </h2>
      <p class="reveal text-sm text-text-muted mb-12">Four revenue streams, executing in parallel. Different customers, different sales cycles, same brain infrastructure.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {REVENUE_SOURCES.map((src) => (
          <div class="reveal glass rounded-xl p-5">
            <div class="flex items-center gap-3 mb-3">
              <span class={`text-sm font-mono font-bold text-${src.color}`}>{src.timeline}</span>
              <h3 class="text-sm font-medium text-text-primary">{src.name}</h3>
            </div>
            <p class="text-[11px] text-text-secondary leading-relaxed">{src.description}</p>
          </div>
        ))}
      </div>

      <div class="reveal glass-bright rounded-xl p-5 mt-6">
        <p class="text-[10px] font-mono text-text-muted uppercase tracking-[0.3em] mb-3">Core Model</p>
        <p class="text-sm text-text-secondary leading-relaxed">
          <span class="text-text-primary font-medium">Brain-as-a-Service is the annuity.</span> Hardware is sold once; the brain is rented monthly.
          At $700/robot/month average, 93% gross margin, and $25K+ lifetime value per robot, the economics compound with every OEM partnership.
          Government contracts fund early R&D without dilution. IP licensing creates a long-tail royalty stream. This is the ARM model applied to neuromorphic robotics.
        </p>
      </div>
    </section>

    <!-- Valuation Rationale -->
    <section class="max-w-5xl mx-auto px-6 mb-32">
      <h2 class="reveal font-display text-[clamp(1.5rem,3vw,2.5rem)] text-text-primary mb-4">
        Valuation context
      </h2>
      <p class="reveal text-sm text-text-muted mb-12">How OSCEN compares to recent AI seed rounds.</p>

      <div class="reveal glass rounded-xl overflow-hidden">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-border">
              <th class="px-5 py-3 text-[10px] font-mono text-text-muted uppercase">Company</th>
              <th class="px-5 py-3 text-[10px] font-mono text-text-muted uppercase">Valuation</th>
              <th class="px-5 py-3 text-[10px] font-mono text-text-muted uppercase">Raised</th>
              <th class="px-5 py-3 text-[10px] font-mono text-text-muted uppercase hidden md:table-cell">Product?</th>
              <th class="px-5 py-3 text-[10px] font-mono text-text-muted uppercase hidden md:table-cell">Patent?</th>
            </tr>
          </thead>
          <tbody>
            {COMPARABLES.map((c) => (
              <tr class:list={[
                "border-b border-border/50",
                c.company === "OSCEN" ? "bg-accent-blue/5" : "hover:bg-white/[0.02]",
              ]}>
                <td class="px-5 py-3">
                  <span class:list={[
                    "text-sm font-medium",
                    c.company === "OSCEN" ? "text-accent-blue" : "text-text-primary",
                  ]}>{c.company}</span>
                  <span class="text-[9px] text-text-muted block mt-0.5">{c.stage}</span>
                </td>
                <td class="px-5 py-3 text-sm font-mono text-accent-amber">{c.valuation}</td>
                <td class="px-5 py-3 text-sm font-mono text-text-secondary">{c.raised}</td>
                <td class="px-5 py-3 text-center hidden md:table-cell">
                  {c.hadProduct ? (
                    <span class="text-accent-green text-xs font-mono">Yes</span>
                  ) : (
                    <span class="text-accent-red text-xs font-mono">No</span>
                  )}
                </td>
                <td class="px-5 py-3 text-center hidden md:table-cell">
                  {c.hadPatent ? (
                    <span class="text-accent-green text-xs font-mono">Yes</span>
                  ) : (
                    <span class="text-accent-red text-xs font-mono">No</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="reveal glass rounded-xl p-4 mt-4">
        <p class="text-[11px] text-text-secondary text-center leading-relaxed">
          OSCEN's seed raise is a fraction of comparable rounds, with a working product and filed patent that most lack.
          This is a capital-efficient entry point into a market where others have raised billions.
        </p>
      </div>
    </section>

    <!-- Non-Dilutive De-Risk -->
    <section class="max-w-5xl mx-auto px-6 mb-32">
      <h2 class="reveal font-display text-[clamp(1.5rem,3vw,2.5rem)] text-text-primary mb-4">
        Non-dilutive de-risk
      </h2>
      <p class="reveal text-sm text-text-muted mb-12">Government and institutional grants that reduce investor risk.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {NON_DILUTIVE.map((nd) => (
          <div class="reveal glass rounded-xl p-4">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm text-text-primary font-medium">{nd.source}</span>
              <span class="text-sm font-mono text-accent-green font-bold">{nd.amount}</span>
            </div>
            <div class="flex items-center gap-3 text-[10px]">
              <span class="text-text-muted">{nd.timeline}</span>
              <span class="px-2 py-0.5 rounded-full bg-accent-blue/10 text-accent-blue font-mono">{nd.status}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="max-w-5xl mx-auto px-6 mb-16">
      <div class="reveal glass-bright rounded-2xl p-8 text-center">
        <p class="ghost-text font-display text-[clamp(1.5rem,3.5vw,2.5rem)] text-text-primary leading-snug mb-4">
          The architecture is running. The patent is filed.<br />
          <span class="italic text-text-secondary">The market is $115B+ and growing.</span>
        </p>
        <p class="text-sm text-text-muted mb-6 max-w-lg mx-auto">
          We know what remains to be proven. This raise is to validate commercially and technically.
        </p>
        <a
          href="mailto:info@oscen.ai?subject=OSCEN%20Seed%20Round"
          class="inline-block px-8 py-3 rounded-full bg-accent-blue/10 border border-accent-blue/20 text-accent-blue font-medium hover:bg-accent-blue/20 hover:border-accent-blue/40 transition-all duration-300"
        >
          Let's talk
        </a>
      </div>
    </section>

    <!-- Nav -->
    <section class="max-w-5xl mx-auto px-6 mb-16">
      <div class="reveal flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/investor-pitch/team"
          class="px-8 py-3 rounded-full border border-border text-text-muted hover:text-text-primary hover:border-border-bright transition-all duration-300"
        >
          Meet the team →
        </a>
        <a
          href="/investor-pitch/demo"
          class="px-8 py-3 rounded-full border border-border text-text-muted hover:text-text-primary hover:border-border-bright transition-all duration-300"
        >
          ← Back to demo
        </a>
      </div>
    </section>
  </main>
</Base>

<script>
  if ("ontouchstart" in window) {
    document.querySelectorAll<HTMLElement>(".expand-card").forEach((card) => {
      card.addEventListener("click", () => card.classList.toggle("expanded"));
    });
  }
</script>
