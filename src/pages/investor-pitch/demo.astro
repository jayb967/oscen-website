---
/**
 * Investor Pitch — Live Demo
 * The brain is running. Show it.
 * 3D visualization, training stats, architecture summary.
 */
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import PitchNav from "../../components/PitchNav.astro";
import { KEY_STATS } from "../../data/pitch";
import { REGIONS, BRAIN_STATS, formatNeurons, rgbToHex } from "../../data/brain";
---

<Base title="Live Demo | OSCEN Investor Pitch" description="1,056,800 spiking neurons training live. 3D brain visualization. Real architecture, real training, real results.">
  <Nav />
  <PitchNav current="demo" />

  <main class="pt-8 pb-24">

    <!-- Header -->
    <section class="max-w-5xl mx-auto px-6 pt-16 mb-12">
      <p class="reveal text-[10px] font-mono text-text-muted uppercase tracking-[0.3em] mb-6">Live Demo</p>
      <h1 class="reveal font-display text-[clamp(2rem,5vw,3.5rem)] text-text-primary leading-[0.9]">
        Not a pitch deck.<br />
        <span class="italic gradient-text">The brain is running.</span>
      </h1>
      <p class="reveal text-text-secondary mt-6 max-w-2xl leading-relaxed">
        Right now, on a dedicated server, 1,056,800 spiking neurons are processing a multimodal video curriculum
        and learning through 6 simultaneous mechanisms.
      </p>
    </section>

    <!-- Brain Viz Embed -->
    <section class="max-w-5xl mx-auto px-6 mb-16">
      <div class="reveal glass-bright rounded-2xl overflow-hidden" style="aspect-ratio: 16/9;">
        <iframe
          src="/brain-viz/"
          class="w-full h-full border-0"
          title="OSCEN Brain 3D Visualization"
          loading="lazy"
        ></iframe>
      </div>
      <p class="text-[9px] text-text-muted text-center mt-3 font-mono">
        Interactive 3D visualization. Drag to rotate. Scroll to zoom. Each sphere is a brain region. Lines are synapse pathways.
      </p>
    </section>

    <!-- Live Training Stats -->
    <section class="max-w-5xl mx-auto px-6 mb-32">
      <h2 class="reveal font-display text-[clamp(1.5rem,3vw,2.5rem)] text-text-primary mb-4">
        Training status
      </h2>

      <div class="reveal glass-bright rounded-2xl p-6 mb-6">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-2 h-2 rounded-full bg-accent-green animate-pulse"></span>
          <span class="text-sm font-mono text-accent-green">Active | Training 24/7</span>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { label: "Neurons", value: KEY_STATS.neurons, color: "text-accent-blue" },
            { label: "Synapses", value: KEY_STATS.synapses, color: "text-accent-cyan" },
            { label: "Training Steps", value: KEY_STATS.trainingSteps, color: "text-accent-green" },
            { label: "Phase", value: KEY_STATS.trainingPhase, color: "text-accent-amber" },
            { label: "Step Rate", value: `${KEY_STATS.stepsPerSec}/sec`, color: "text-accent-purple" },
            { label: "Curriculum", value: `${KEY_STATS.trainingVideos} videos`, color: "text-accent-pink" },
            { label: "Server Cost", value: KEY_STATS.serverCost, color: "text-accent-blue" },
            { label: "Learning Rules", value: `${KEY_STATS.learningRules} active`, color: "text-accent-cyan" },
          ].map((s) => (
            <div class="text-center">
              <div class={`text-lg font-mono font-bold ${s.color}`}>{s.value}</div>
              <div class="text-[9px] text-text-muted mt-1 uppercase tracking-wider">{s.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Developmental Phase Progress -->
      <div class="reveal glass rounded-xl p-5">
        <p class="text-[10px] font-mono text-text-muted uppercase tracking-[0.3em] mb-4">Developmental Phase</p>
        <div class="flex items-center gap-1 mb-3">
          {[
            { phase: "Infant", width: "6%", active: false },
            { phase: "Toddler", width: "24%", active: false },
            { phase: "Juvenile", width: "20%", active: false },
            { phase: "Adolescent", width: "25%", active: true },
            { phase: "Mature", width: "25%", active: false },
          ].map((p) => (
            <div class="flex-1 flex flex-col items-center gap-1.5">
              <div
                class:list={[
                  "w-full h-2 rounded-full",
                  p.active ? "bg-accent-green" : "bg-elevated",
                  !p.active && p.phase === "Infant" && "bg-accent-blue/30",
                  !p.active && p.phase === "Toddler" && "bg-accent-blue/30",
                  !p.active && p.phase === "Juvenile" && "bg-accent-blue/30",
                ]}
              ></div>
              <span class:list={[
                "text-[8px] font-mono",
                p.active ? "text-accent-green" : "text-text-muted/50",
              ]}>{p.phase}</span>
            </div>
          ))}
        </div>
        <p class="text-[10px] text-text-secondary">
          Currently in <span class="text-accent-green font-medium">adolescent phase</span>.
          Adolescent entry was experience-dependent: required concept differentiation, sensory stability,
          and feature STDP decline. Not hardcoded by step count.
        </p>
      </div>
    </section>

    <!-- Brain Regions -->
    <section class="max-w-5xl mx-auto px-6 mb-32">
      <h2 class="reveal font-display text-[clamp(1.5rem,3vw,2.5rem)] text-text-primary mb-4">
        Brain architecture
      </h2>
      <p class="reveal text-sm text-text-muted mb-12">
        {BRAIN_STATS.brainRegions} regions, {BRAIN_STATS.synapseGroups} synapse pathways,
        {BRAIN_STATS.learningMechanisms} simultaneous learning mechanisms.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {REGIONS.map((r, i) => (
          <div class="expand-card reveal glass rounded-xl p-4 cursor-pointer group" tabindex="0" style={`--glow-delay: ${i * 1.2}s; --glow-color: var(--color-accent-blue);`}>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span
                  class="w-3 h-3 rounded-full shrink-0"
                  style={`background: ${rgbToHex(r.color)}`}
                ></span>
                <div>
                  <span class="text-sm text-text-primary">{r.label}</span>
                  <span class="text-[10px] font-mono text-text-muted ml-2">{formatNeurons(r.neurons)}</span>
                </div>
              </div>
              <span class="expand-indicator text-text-muted/40 text-sm">+</span>
            </div>
            <div class="expand-body mt-3 ml-6">
              <p class="text-[11px] text-text-secondary leading-relaxed">{r.description}</p>
              <p class="text-[9px] text-text-muted mt-1">{r.connections}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- 6 Learning Rules -->
    <section class="max-w-5xl mx-auto px-6 mb-32">
      <h2 class="reveal font-display text-[clamp(1.5rem,3vw,2.5rem)] text-text-primary mb-4">
        6 simultaneous learning rules
      </h2>
      <p class="reveal text-sm text-text-muted mb-12">All running on every simulation step. This is what the patent protects.</p>

      <div class="reveal glass-bright rounded-2xl p-6">
        <div class="space-y-4">
          {[
            { num: "1", name: "STDP", full: "Spike-Timing Dependent Plasticity", desc: "Neurons that fire together, wire together. Configurable per synapse group." },
            { num: "2", name: "Eligibility Traces", full: "Three-Factor Learning", desc: "STDP changes are accumulated as traces, then applied when neuromodulators arrive. Bridges the temporal gap." },
            { num: "3", name: "BCM Metaplasticity", full: "Bienenstock-Cooper-Munro", desc: "Per-neuron sliding threshold. Active neurons become harder to potentiate. Prevents winner-take-all collapse." },
            { num: "4", name: "Neuromodulation", full: "4-Channel Chemical Signaling", desc: "Dopamine, acetylcholine, norepinephrine, serotonin. Gate eligibility trace application. Drive exploration vs exploitation." },
            { num: "5", name: "Homeostatic Scaling", full: "Synaptic Normalization", desc: "Per-neuron multiplicative scaling. Prevents runaway excitation. Preserves learned representations during new learning." },
            { num: "6", name: "R-STDP", full: "Reward-modulated STDP", desc: "Prediction error scales weight changes on motor pathways. The brain learns from outcomes, not just correlations." },
          ].map((rule) => (
            <div class="flex gap-4 items-start">
              <span class="text-accent-blue font-mono text-sm font-bold mt-0.5 shrink-0">{rule.num}</span>
              <div>
                <div class="flex items-center gap-2">
                  <span class="text-sm text-text-primary font-medium">{rule.name}</span>
                  <span class="text-[9px] text-text-muted font-mono">{rule.full}</span>
                </div>
                <p class="text-[11px] text-text-secondary leading-relaxed mt-0.5">{rule.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- What this means -->
    <section class="max-w-5xl mx-auto px-6 mb-32">
      <div class="reveal glass rounded-2xl p-8 text-center">
        <p class="ghost-text font-display text-[clamp(1.2rem,3vw,2rem)] text-text-primary leading-snug">
          This is not a simulation of intelligence.<br />
          <span class="italic text-text-secondary">It's the mechanism of it.</span>
        </p>
      </div>
    </section>

    <!-- Nav -->
    <section class="max-w-5xl mx-auto px-6 mb-16">
      <div class="reveal flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/investor-pitch/ask"
          class="px-8 py-3 rounded-full bg-accent-blue/10 border border-accent-blue/20 text-accent-blue font-medium hover:bg-accent-blue/20 hover:border-accent-blue/40 transition-all duration-300"
        >
          See the ask →
        </a>
        <a
          href="/investor-pitch/market"
          class="px-8 py-3 rounded-full border border-border text-text-muted hover:text-text-primary hover:border-border-bright transition-all duration-300"
        >
          ← Market opportunity
        </a>
      </div>
    </section>
  </main>
</Base>

<script>
  if ("ontouchstart" in window) {
    document.querySelectorAll<HTMLElement>(".expand-card").forEach((card) => {
      card.addEventListener("click", () => card.classList.toggle("expanded"));
    });
  }
</script>
