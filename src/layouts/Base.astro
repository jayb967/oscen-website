---
import CookieConsent from "../components/CookieConsent.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = "A brain-inspired AI that learns like a child, through experience, not training data. Patent pending.",
  ogImage = "/og-default.png",
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN ?? "oscen.ai";
const plausibleEnabled = import.meta.env.PUBLIC_PLAUSIBLE_ENABLED === "true";
// Hardcoded fallback so the tag ships even before the Netlify env var is
// configured. Env var override still wins when present.
const metaDomainVerification =
  import.meta.env.PUBLIC_META_DOMAIN_VERIFICATION ??
  "nyjtlqf651sxfcwau3ne8fpoikry0a";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
    <link rel="canonical" href={canonicalURL} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {metaDomainVerification && (
      <meta name="facebook-domain-verification" content={metaDomainVerification} />
    )}

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="OSCEN" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Fonts: preconnect then load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&family=Outfit:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {plausibleEnabled && (
      <script defer data-domain={plausibleDomain} src="https://plausible.io/js/script.outbound-links.js"></script>
    )}
  </head>
  <body>
    <slot />

    <!-- Global legal strip. Sits below per-page footers. Privacy + Terms +
         a reopen-consent button so users can change their tracking choice. -->
    <div class="border-t border-border/40 py-4 px-6 text-center">
      <p class="text-[10px] text-text-muted/60 font-mono space-x-4">
        <a href="/privacy" class="hover:text-accent-blue transition-colors">Privacy</a>
        <span aria-hidden="true">&middot;</span>
        <a href="/terms" class="hover:text-accent-blue transition-colors">Terms</a>
        <span aria-hidden="true">&middot;</span>
        <button type="button" data-consent-reopen class="hover:text-accent-blue transition-colors cursor-pointer">Cookie preferences</button>
      </p>
    </div>

    <!-- Consent banner: ships HTML up-front so the runtime can show it as soon
         as oscenConsent loads. Internally consent-gates pixel + GTM. -->
    <CookieConsent />

    <!-- First-touch UTM + referrer capture (must load before form scripts). -->
    <script>
      import "../scripts/attribution";
    </script>

    <!-- Consent state machine. Must load before meta-pixel + gtm because both
         gate their boot on window.oscenConsent. -->
    <script>
      import "../scripts/consent";
    </script>

    <!-- Meta Pixel loader. No-op until consent:granted; exposes window.metaTrack. -->
    <script>
      import "../scripts/meta-pixel";
    </script>

    <!-- Google Tag Manager loader. Same consent gate; exposes window.gtmPush. -->
    <script>
      import "../scripts/gtm";
    </script>

    <!-- GSAP ScrollTrigger animations -->
    <script>
      import "../scripts/scroll-animations";
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
