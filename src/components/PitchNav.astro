---
/**
 * Sub-navigation for investor-pitch pages.
 * Horizontal pill tabs. Highlights current page.
 */
interface Props {
  current: string;
}

const { current } = Astro.props;

const tabs = [
  { href: "/investor-pitch", label: "Overview", id: "overview" },
  { href: "/investor-pitch/market", label: "Market", id: "market" },
  { href: "/investor-pitch/demo", label: "Demo", id: "demo" },
  { href: "/investor-pitch/ask", label: "The Ask", id: "ask" },
  { href: "/investor-pitch/team", label: "Team", id: "team" },
];
---

<div class="sticky top-[72px] z-50 glass border-b border-border">
  <div class="max-w-5xl mx-auto px-6 py-3 flex items-center gap-1 overflow-x-auto scrollbar-hide">
    {tabs.map((tab) => (
      <a
        href={tab.href}
        class:list={[
          "px-4 py-1.5 text-[11px] font-mono tracking-wide rounded-full whitespace-nowrap transition-all duration-300",
          current === tab.id
            ? "bg-accent-blue/10 border border-accent-blue/30 text-accent-blue"
            : "text-text-muted hover:text-text-primary hover:bg-white/[0.03]",
        ]}
      >
        {tab.label}
      </a>
    ))}
    <span class="ml-auto hidden md:inline-flex items-center gap-2">
      <span class="w-1.5 h-1.5 rounded-full bg-accent-green animate-pulse"></span>
      <span class="text-[9px] font-mono text-text-muted">Live training</span>
    </span>
  </div>
</div>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>
