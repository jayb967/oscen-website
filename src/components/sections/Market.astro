---
/**
 * Section: Market — Competitive landscape and market opportunity.
 * Numbers-first. Comparison table. The "why now" case.
 */
const competitors = [
  { name: "AMI Labs (LeCun)", approach: "JEPA World Models", learning: "Retrain", edge: "No", energy: "50–200W", funding: "$1.03B" },
  { name: "Figure AI", approach: "VLA Transformer (Helix)", learning: "Static", edge: "No", energy: "50–200W", funding: "$1.9B" },
  { name: "Google DeepMind", approach: "Gemini Robotics VLA", learning: "Retrain", edge: "Partial", energy: "50–200W", funding: "Internal" },
  { name: "Physical Intelligence", approach: "3B param VLA", learning: "Static", edge: "Cloud", energy: "50–200W", funding: "$1.1B" },
  { name: "OSCEN", approach: "Spiking Neural Net", learning: "Continual", edge: "Yes", energy: "<5W*", funding: "Bootstrapped" },
];

const stats = [
  { value: "$1.4T", label: "Robotics market by 2030", sub: "Goldman Sachs", color: "text-accent-blue" },
  { value: "$200M+", label: "Neuromorphic VC in 2025", sub: "3x increase from 2024", color: "text-accent-amber" },
  { value: "73–109×", label: "Energy advantage on neuromorphic HW", sub: "Intel Loihi benchmarks", color: "text-accent-green" },
  { value: "0", label: "SNN robotics competitors", sub: "Commercial deployment", color: "text-accent-purple" },
];
---

<section id="market" class="section relative">
  <div class="max-w-5xl mx-auto w-full">
    <div class="text-center mb-20">
      <p class="reveal text-[10px] font-mono text-text-muted uppercase tracking-[0.3em] mb-6">The Market</p>
      <h2 class="reveal font-display text-[clamp(2rem,5vw,3.5rem)] text-text-primary leading-tight">
        Everyone is building the body.<br />
        <span class="italic gradient-text">No one is building the brain.</span>
      </h2>
    </div>

    <!-- Market stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-16">
      {stats.map((s) => (
        <div class="flip-card reveal h-36" tabindex="0" role="button" aria-label={`${s.value}: ${s.label}`}>
          <div class="flip-inner w-full h-full">
            <div class="flip-front w-full h-full glass-bright rounded-xl p-4 flex flex-col items-center justify-center text-center">
              <div class={`text-xl md:text-2xl font-mono font-bold ${s.color}`}>{s.value}</div>
              <div class="text-[10px] text-text-muted mt-2 uppercase tracking-wider leading-tight">{s.label}</div>
            </div>
            <div class="flip-back w-full h-full glass rounded-xl p-4 flex items-center justify-center text-center">
              <p class="text-[11px] text-text-secondary">{s.sub}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Competitor comparison -->
    <div class="reveal glass rounded-xl overflow-hidden mb-8">
      <div class="overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left p-4 text-text-muted font-mono font-normal uppercase tracking-wider">Company</th>
              <th class="text-left p-4 text-text-muted font-mono font-normal uppercase tracking-wider">Approach</th>
              <th class="text-left p-4 text-text-muted font-mono font-normal uppercase tracking-wider">Learning</th>
              <th class="text-left p-4 text-text-muted font-mono font-normal uppercase tracking-wider">Edge</th>
              <th class="text-left p-4 text-text-muted font-mono font-normal uppercase tracking-wider">Power</th>
            </tr>
          </thead>
          <tbody>
            {competitors.map((row) => {
              const isOscen = row.name === "OSCEN";
              return (
                <tr class={`border-b border-border/50 ${isOscen ? 'bg-accent-blue/[0.03]' : ''}`}>
                  <td class={`p-4 ${isOscen ? 'text-accent-blue font-medium' : 'text-text-primary'}`}>{row.name}</td>
                  <td class="p-4 text-text-secondary">{row.approach}</td>
                  <td class={`p-4 ${row.learning === 'Continual' ? 'text-accent-green' : 'text-text-muted'}`}>{row.learning}</td>
                  <td class={`p-4 ${row.edge === 'Yes' ? 'text-accent-green' : 'text-text-muted'}`}>{row.edge}</td>
                  <td class={`p-4 font-mono ${isOscen ? 'text-accent-green' : 'text-text-muted'}`}>{row.energy}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>

    <p class="reveal text-[10px] text-text-muted text-center font-mono">
      * On neuromorphic hardware (Intel Loihi target). Currently training on CPU at ~45W.
    </p>
  </div>
</section>
