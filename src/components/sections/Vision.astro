---
/**
 * Section 5: Vision — Where this goes. The picture that makes investors lean forward.
 * Three columns. Nine words default. Expand for depth.
 */
const pillars = [
  {
    icon: "◎",
    title: "Any intelligence",
    body: "From 1 million neurons today to eventually 86 billion, like humans. From baby videos to embodied manipulation. From one brain to a fleet sharing learned experiences.",
    accent: "accent-blue",
  },
  {
    icon: "◈",
    title: "Any hardware",
    body: "Software simulation today. Custom neuromorphic silicon tomorrow. We're building our own chip, purpose-designed for spiking neural networks and edge deployment. 1000× energy reduction, no dependency on third-party hardware roadmaps.",
    accent: "accent-cyan",
  },
  {
    icon: "◇",
    title: "Any body",
    body: "Robot arms. Humanoids. Surgical assistants. Any sensor, any actuator, any form factor. The brain travels between bodies. The body is interchangeable.",
    accent: "accent-purple",
  },
];
---

<section id="vision" class="section relative">
  <div class="max-w-4xl mx-auto w-full">
    <div class="text-center mb-20">
      <p class="reveal text-[10px] font-mono text-text-muted uppercase tracking-[0.3em] mb-6">Vision</p>
      <h2 class="reveal font-display text-[clamp(2rem,5vw,3.5rem)] text-text-primary leading-tight">
        The brain for<br />
        <span class="italic gradient-text">every robot.</span>
      </h2>
    </div>

    <!-- Three pillars -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-24">
      {pillars.map((p, i) => (
        <div class="expand-card reveal glass rounded-2xl p-6 cursor-pointer group text-center" tabindex="0" style={`--glow-delay: ${i * 2}s; --glow-color: var(--color-${p.accent});`}>
          <span class={`text-2xl text-${p.accent}/50 group-hover:text-${p.accent} transition-colors duration-300`}>{p.icon}</span>
          <h3 class="text-text-primary font-medium mt-3">{p.title}</h3>
          <span class={`expand-indicator inline-block mt-2 text-${p.accent}/30 text-sm`}>+</span>
          <div class="expand-body mt-3">
            <p class="text-sm text-text-secondary leading-relaxed">{p.body}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Founder signal — the emotional gut-punch for investors -->
    <div class="text-center">
      <div class="divider max-w-24 mx-auto mb-14"></div>
      <p id="founder-line" class="ghost-text font-display text-[clamp(1.5rem,3.5vw,2.5rem)] text-text-primary leading-snug">
        Nearly a decade of neuroscience research. 7 months of focused build.<br />
        <span class="italic text-text-secondary">One founder. Imagine what a team does.</span>
      </p>
    </div>
  </div>
</section>

<script>
  if ("ontouchstart" in window) {
    document.querySelectorAll<HTMLElement>("#vision .expand-card").forEach((card) => {
      card.addEventListener("click", () => card.classList.toggle("expanded"));
    });
  }
</script>
