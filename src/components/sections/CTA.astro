---
/**
 * Section 6: CTA — One moment of decision. Three paths. Email capture.
 */
const paths = [
  {
    title: "Invest",
    desc: "Seed-stage opportunity. Patent-protected neuromorphic intelligence.",
    href: "/invest",
    accent: "accent-amber",
  },
  {
    title: "Partner",
    desc: "Integrate with your robot platform, edge hardware, or silicon.",
    href: "/contact",
    accent: "accent-blue",
  },
  {
    title: "Research",
    desc: "Academic collaboration on SNN learning and neuromorphic deployment.",
    href: "/research",
    accent: "accent-purple",
  },
];
---

<section id="cta" class="section relative">
  <div class="max-w-4xl mx-auto w-full">
    <div class="text-center mb-16">
      <h2 class="reveal font-display text-[clamp(2rem,5vw,3.5rem)] text-text-primary leading-tight">
        Build the future of<br />
        <span class="italic gradient-text">embodied intelligence.</span>
      </h2>
    </div>

    <!-- Three paths -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-16">
      {paths.map((p) => (
        <a
          href={p.href}
          class={`reveal glass rounded-2xl p-6 group hover:border-border-bright transition-all duration-300 block text-center`}
        >
          <div class={`text-lg font-medium text-${p.accent} group-hover:translate-y-[-2px] transition-transform duration-300`}>
            {p.title}
          </div>
          <p class="text-xs text-text-muted mt-2 leading-relaxed">{p.desc}</p>
          <div class={`mt-4 text-[10px] font-mono text-${p.accent}/40 group-hover:text-${p.accent} transition-colors`}>→</div>
        </a>
      ))}
    </div>

    <!-- Email capture — one field, maximum conversion -->
    <div class="reveal max-w-md mx-auto">
      <form id="email-form" class="flex gap-2" action="/api/subscribe" method="POST">
        <input
          type="email"
          name="email"
          required
          placeholder="your@email.com"
          class="flex-1 px-4 py-2.5 rounded-lg bg-void/50 border border-border text-sm text-text-primary placeholder-text-muted/40 focus:border-accent-blue/30 focus:outline-none transition-colors"
        />
        <button
          type="submit"
          class="px-6 py-2.5 rounded-lg bg-accent-blue/10 border border-accent-blue/20 text-accent-blue text-sm font-medium hover:bg-accent-blue/20 hover:border-accent-blue/40 transition-all duration-300 cursor-pointer whitespace-nowrap"
        >
          Stay informed
        </button>
        <!-- Honeypot -->
        <div class="hidden" aria-hidden="true">
          <input type="text" name="website" tabindex="-1" autocomplete="off" />
        </div>
      </form>
    </div>

    <!-- Footer — one line -->
    <footer class="mt-28 text-center">
      <div class="divider max-w-16 mx-auto mb-8"></div>
      <p class="text-xs text-text-muted font-mono">
        OSCEN &nbsp;&middot;&nbsp; Patent Pending &nbsp;&middot;&nbsp; US 63/986,737 &nbsp;&middot;&nbsp; &copy; {new Date().getFullYear()}
      </p>
      <div class="mt-3 flex items-center justify-center gap-4">
        <a href="mailto:info@oscen.ai" class="text-[10px] text-text-muted/60 hover:text-accent-blue transition-colors font-mono">info@oscen.ai</a>
        <a href="https://linkedin.com/in/rio-bold" target="_blank" rel="noopener" class="text-[10px] text-text-muted/60 hover:text-accent-blue transition-colors font-mono">LinkedIn</a>
        <a href="/architecture" class="text-[10px] text-text-muted/60 hover:text-accent-blue transition-colors font-mono">Docs</a>
      </div>
    </footer>
  </div>
</section>
