---
/**
 * Final section. poetic close, single newsletter form, footer.
 *
 * The three conversion paths live in <ThreePaths /> above; this section is
 * just the email-capture finale + legal/footer.
 */
import { BUTTONDOWN_ACTION } from "../../lib/forms";
---

<section id="cta" class="section relative">
  <div class="max-w-4xl mx-auto w-full">
    <div class="text-center mb-12">
      <h2 class="reveal font-display text-[clamp(2rem,5vw,3.5rem)] text-text-primary leading-tight">
        Build the future of<br />
        <span class="italic gradient-text">embodied intelligence.</span>
      </h2>
    </div>

    <div id="email-capture" class="reveal max-w-md mx-auto scroll-mt-24">
      <form id="email-form" class="flex gap-2" action={BUTTONDOWN_ACTION} method="POST" target="popupwindow">
        <input
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder="your@email.com"
          class="flex-1 px-4 py-2.5 rounded-lg bg-void/50 border border-border text-sm text-text-primary placeholder-text-muted/40 focus:border-accent-blue/30 focus:outline-none transition-colors"
        />
        <input type="hidden" name="tag" value="follower" />
        <input type="hidden" name="embed" value="1" />
        <button
          type="submit"
          id="subscribe-submit"
          class="px-6 py-2.5 rounded-lg bg-accent-blue/10 border border-accent-blue/20 text-accent-blue text-sm font-medium hover:bg-accent-blue/20 hover:border-accent-blue/40 transition-all duration-300 cursor-pointer whitespace-nowrap"
        >
          Follow the build
        </button>
      </form>
      <p id="subscribe-status" class="text-center text-sm font-mono mt-3 hidden"></p>
    </div>

    <footer class="mt-28 text-center">
      <div class="divider max-w-16 mx-auto mb-8"></div>
      <p class="text-xs text-text-muted font-mono">
        OSCEN &nbsp;&middot;&nbsp; Patent Pending &nbsp;&middot;&nbsp; US 63/986,737 &nbsp;&middot;&nbsp; &copy; {new Date().getFullYear()}
      </p>
      <div class="mt-3 flex items-center justify-center gap-4 flex-wrap">
        <a href="mailto:info@oscen.ai" class="text-[10px] text-text-muted/60 hover:text-accent-blue transition-colors font-mono">info@oscen.ai</a>
        <a href="/architecture" class="text-[10px] text-text-muted/60 hover:text-accent-blue transition-colors font-mono">Docs</a>
        <a href="/support" class="text-[10px] text-text-muted/60 hover:text-accent-amber transition-colors font-mono">Support</a>
      </div>
    </footer>
  </div>
</section>

<script>
  import { subscribeButtondown } from "../../lib/forms";

  const form = document.getElementById("email-form") as HTMLFormElement | null;
  const btn = document.getElementById("subscribe-submit") as HTMLButtonElement | null;
  const status = document.getElementById("subscribe-status") as HTMLElement | null;

  if (form && btn && status) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      subscribeButtondown(form, btn, status);
    });
  }
</script>
