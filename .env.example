# OSCEN website env vars. Copy to .env.local for dev; set in Netlify for prod.
# All vars are prefixed PUBLIC_ because Astro inlines them into the client bundle.
#
# Formspree IDs and Buttondown handle are baked as defaults in src/lib/forms.ts.
# Set these only if you want to override (e.g., staging environments).

# Your Buttondown handle (visible at buttondown.com/<handle>). Defaults to "oscen".
# PUBLIC_BUTTONDOWN_USERNAME=oscen

# Override Formspree form IDs if needed (defaults are the production forms).
# PUBLIC_FORMSPREE_INVESTOR_ID=mjgdnzjw
# PUBLIC_FORMSPREE_BUILD_ID=mzdqnwyy
# PUBLIC_FORMSPREE_CONTACT_ID=xzdkgdol

# Plausible analytics. Set ENABLED=true after adding the domain in Plausible.
PUBLIC_PLAUSIBLE_DOMAIN=oscen.ai
PUBLIC_PLAUSIBLE_ENABLED=false
